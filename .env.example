# Local development defaults to SQLite. Docker Compose supplies PostgreSQL.
DATABASE_URL=sqlite:///./platform.db
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
SIMULATION_INTERVAL_SECONDS=1
SIMULATION_AUTOSTART=true
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# Use a long random value in production. Changing it signs out existing users.
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_ACCESS_TOKEN_MINUTES=1440

# SMTP email verification. Example values work for QQ Mail after replacing
# the account and authorization code; SMTP_PASSWORD is not the mailbox password.
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=your-account@qq.com
SMTP_PASSWORD=your-smtp-authorization-code
SMTP_FROM_EMAIL=your-account@qq.com
SMTP_USE_SSL=true
SMTP_USE_TLS=false
EMAIL_CODE_EXPIRE_MINUTES=10
EMAIL_CODE_RESEND_SECONDS=60
